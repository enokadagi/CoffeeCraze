{
  "name": "coffeecraze",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup-backend": "node create-structure-now.js",
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
    "start": "node dist/server.mjs",
    "clean": "rm -rf dist server.js",
    "pages:dev": "wrangler pages dev dist --port 8788",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name coffeecraze",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "design:enforce": "node scripts/design-enforce.js",
    "lint:all": "npm run lint && npm run design:enforce"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.7",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/google.accounts": "^0.0.18",
    "@types/node": "^22.14.0",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "puppeteer": "^25.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  }
}
