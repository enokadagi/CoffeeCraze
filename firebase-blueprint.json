{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "wholesale", "customer"] },
        "loyaltyPoints": { "type": "number" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboarded": { "type": "boolean" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "sku": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isSubscriptionEligible": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isFeatured": { "type": "boolean" }
      }
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User coffee subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused", "cancelled"] },
        "nextDelivery": { "type": "string", "format": "date-time" },
        "frequency": { "type": "string", "enum": ["weekly", "biweekly", "monthly"] },
        "items": { "type": "array" },
        "address": { "type": "object" },
        "history": { "type": "array" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Sales order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "trackingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WholesaleAccount": {
        "title": "Wholesale Account",
        "description": "Wholesale buyer details and pricing",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "businessName": { "type": "string" },
            "businessType": { "type": "string" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "taxId": { "type": "string" },
            "customPricing": { "type": "object" }
        }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Store products" },
    "/categories/{categoryId}": { "schema": "object", "description": "Product categories" },
    "/subscriptions/{subId}": { "schema": "Subscription", "description": "User subscriptions" },
    "/orders/{orderId}": { "schema": "Order", "description": "Store orders" },
    "/wholesale_accounts/{userId}": { "schema": "WholesaleAccount", "description": "Wholesale status" },
    "/reviews/{reviewId}": { "schema": "object", "description": "Product reviews" },
    "/coupons/{couponId}": { "schema": "object", "description": "Discount coupons" }
  }
}
