rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'admin'];
    }

    // Default: read public assets, no writes
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Product images — admin only
    match /products/{imageId} {
      allow read: if true;
      allow write, delete: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // CMS images — admin only
    match /cms/{imageId} {
      allow read: if true;
      allow write, delete: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Blog images — admin only
    match /blog/{imageId} {
      allow read: if true;
      allow write, delete: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // User profile uploads — owner only
    match /uploads/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write, delete: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Profile images — owner only (used by Profile.tsx and Settings.tsx)
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
