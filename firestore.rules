rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['admin', 'wholesale', 'customer'];
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Profile Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'onboarded', 'referralCode', 'loyaltyPoints', 'phone', 'address'])) ||
        // Action: Admin Role Update
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'loyaltyPoints']))
      );
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wishlist/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'trackingId']);
    }

    match /subscriptions/{subId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'nextDelivery', 'frequency', 'items']);
    }

    match /wholesale_accounts/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId);
      allow update: if isAdmin();
    }
  }
}
