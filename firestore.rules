rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global deny — explicit allows only
    match /{document=**} { allow read, write: if false; }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    // Strict admin: only owner, super_admin and admin roles
    function isAdmin() {
      return isSignedIn() && getUserRole() in ['owner', 'super_admin', 'admin'];
    }

    // Any back-office staff role (all non-customer, non-wholesale)
    function isStaff() {
      return isSignedIn() && getUserRole() in [
        'owner', 'super_admin', 'admin', 'manager', 'accounting',
        'customer_service', 'inventory', 'warehouse', 'barista',
        'marketing', 'supplier_manager', 'support', 'analyst',
        'product_manager', 'wholesale_manager'
      ];
    }

    // Driver: can view/update only their assigned deliveries
    function isDriver() {
      return isSignedIn() && getUserRole() == 'driver';
    }

    // Granular permission check: reads a 'permissions' string array on the user profile
    // Usage: hasPermission('orders:write')
    function hasPermission(perm) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && perm in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', []);
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && data.role in [
          'owner', 'super_admin', 'admin', 'manager', 'accounting',
          'customer_service', 'inventory', 'warehouse', 'barista',
          'marketing', 'supplier_manager', 'support', 'analyst',
          'product_manager', 'wholesale_manager',
          'wholesale', 'customer', 'driver'
        ];
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.items is list && data.items.size() > 0
        && data.total is number && data.total >= 0
        && data.status in ['pending', 'confirmed', 'processing', 'preparing', 'ready', 'shipped', 'out_for_delivery', 'delivered', 'cancelled']
        && data.paymentMethod in ['cash_on_delivery', 'card', 'bank_transfer'];
    }

    function isValidContactMessage(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.status == 'unread';
    }

    function isValidWholesaleInquiry(data) {
      return data.userId == request.auth.uid
        && data.businessName is string && data.businessName.size() > 0 && data.businessName.size() <= 200
        && data.location is string && data.location.size() > 0 && data.location.size() <= 200
        && data.status == 'pending';
    }

    function isValidFaq(data) {
      return data.question is string && data.question.size() > 0
        && data.answer is string && data.answer.size() > 0
        && data.order is number;
    }

    // Owner updating own profile: only profile fields, never role/permissions/status
    function isOwnerProfileUpdate() {
      return !('role' in incoming())
        && !('permissions' in incoming())
        && !('status' in incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'phone', 'address', 'addresses', 'defaultAddressId',
          'avatar', 'profileImage', 'preferences', 'onboarded', 'updatedAt'
        ]);
    }

    // Non-staff blog engagement: only counters
    function isBlogEngagementUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly([
        'likesCount', 'sharesCount', 'commentsCount'
      ]);
    }

    // Subscription owner pausing/cancelling
    function isOwnerSubscriptionUpdate() {
      return request.auth.uid == resource.data.userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        && incoming().status in ['paused', 'cancelled'];
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn() && request.auth.uid == userId && (!('role' in incoming()) || incoming().role == 'customer');
      allow update: if isAdmin() || (request.auth.uid == userId && isOwnerProfileUpdate());
      allow delete: if isAdmin();
    }

    // --- Products (public read) ---
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    // --- Subscription plans (public read) ---
    match /plans/{planId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    // --- CMS (public read visible only) ---
    match /cms_content/{docId} {
      allow get: if resource.data.visible == true || isStaff();
      allow list: if isStaff() || (resource.data.visible == true);
      allow create, update, delete: if isStaff();
    }

    // --- Blog (public read published; engagement updates allowed) ---
    match /blog_posts/{postId} {
      allow get: if resource.data.status == 'published' || isStaff();
      allow list: if isStaff() || resource.data.status == 'published';
      allow create, delete: if isStaff();
      allow update: if isStaff() || (resource.data.status == 'published' && isBlogEngagementUpdate());
    }

    // --- FAQs (public read visible only) ---
    match /faqs/{faqId} {
      allow get: if resource.data.visible == true || isStaff();
      allow list: if isStaff() || (resource.data.visible == true);
      allow create: if isStaff() && isValidFaq(incoming());
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // --- Contact messages ---
    match /contact_messages/{messageId} {
      allow create: if isValidContactMessage(incoming());
      allow get, list, update, delete: if isStaff();
      match /replies/{replyId} {
        allow create, read: if isStaff();
      }
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified()
        && incoming().userId == request.auth.uid
        && incoming().productId is string
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5;
      allow update, delete: if isStaff();
    }

    // --- Wishlist ---
    match /wishlist/{userId} {
      allow get, write: if isOwner(userId);
    }

    // --- Orders ---
    match /orders/{orderId} {
      // Customers can read their own; staff can read all; drivers can read orders assigned to them
      allow get: if isSignedIn() && (
        isOwner(existing().userId)
        || isStaff()
        || (isDriver() && existing().get('driverId', '') == request.auth.uid)
      );
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isStaff()
        || (isDriver() && resource.data.get('driverId', '') == request.auth.uid)
      );
      // Use isSignedIn instead of isVerified because the ID token's email_verified
      // claim may lag behind the actual user.emailVerified after verification.
      // Client already checks emailVerified before calling create.
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().status == 'pending';
      // Staff can update order fields; drivers can only mark as delivered and set paymentStatus
      allow update: if
        (isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'trackingId', 'paymentStatus', 'driverId', 'driverName', 'updatedAt', 'deliveredAt']))
        || (isDriver() && existing().get('driverId', '') == request.auth.uid
            && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'deliveredAt', 'updatedAt'])
            && incoming().status == 'delivered');
      allow delete: if isStaff();
    }

    // --- Subscriptions ---
    match /subscriptions/{subId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isStaff());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update: if isStaff() || isOwnerSubscriptionUpdate();
      allow delete: if isStaff();
    }

    // --- Deliveries ---
    match /deliveries/{deliveryId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isStaff());
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isStaff();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isStaff());
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isVerified() && incoming().userId == request.auth.uid
        && incoming().amount is number && incoming().amount >= 0
        && incoming().currency in ['LBP', 'USD']
        && incoming().method in ['cash_on_delivery', 'card', 'bank_transfer'];
      allow update, delete: if isStaff();
    }

    // --- Payment ledgers ---
    match /paymentLedgers/{ledgerId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isStaff());
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isVerified() && incoming().userId == request.auth.uid
        && incoming().amount is number && incoming().amount >= 0
        && incoming().currency in ['LBP', 'USD'];
      allow update, delete: if isStaff();
    }

    // --- Site Settings ---
    match /site_settings/{docId} {
      allow get: if true;
      allow list: if isStaff();
      allow create, update: if isStaff();
    }

    // --- Carts (user-owned) ---
    match /carts/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Audit Logs ---
    match /audit_logs/{logId} {
      allow create: if isStaff();
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }

    // --- Wholesale inquiries ---
    match /wholesale_accounts/{accountId} {
      allow get: if isStaff() || (isSignedIn() && existing().userId == request.auth.uid);
      allow list: if isStaff();
      allow create: if isVerified() && isValidWholesaleInquiry(incoming());
      allow update, delete: if isStaff();
    }

    // --- Offers (AI-generated, admin approved) ---
    match /offers/{offerId} {
      allow read: if isStaff() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Coupons ---
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // --- Employee Invites ---
    match /employee_invites/{email} {
      allow read, write: if isStaff();
    }

    // --- Employees ---
    match /employees/{employeeId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }
  }
}
