# Firebase (client — safe to expose in frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Gemini AI — used by Cloudflare Pages Function at functions/api/ai/chat.ts
# Production: set as a secret in Cloudflare Dashboard → Pages → coffeecraze → Settings → Environment variables
# Local dev: set in .env
GEMINI_API_KEY=

# SMTP — required for wholesale inquiry email notifications (local dev only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
